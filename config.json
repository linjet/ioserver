{
    "service": "Load-Balanced Data Input/Output Service",
    "shortname": "LBD IO Service",
    "runame": "Сервис ввода/вывода данных c балансировкой нагрузки",
    "version": "10.0.0.1",
    "adapter": "Ethernet 5",
    "port": 80,
    "timeout": 60000,
    "buffer": 4096,
    "encoding": "utf-8",
    "tls": null,
    "maxconnections": 0,
    "observation": 1000,
    "authorization": "~/authentication/authorization/authentication/check",
    "dataparser": "/iostatic/iostatic/dataparser/parsing",
    "plugins":
    [
        "\\plug-ins\\authentication.dll"
    ]
}